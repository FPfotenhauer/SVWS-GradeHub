{
  "name": "svws-gradehub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:offline": "vite --config vite.offline.config.ts",
    "build": "vue-tsc --noEmit && vite build --config vite.offline.config.ts",
    "build:web": "vue-tsc --noEmit && vite build",
    "build:offline": "npm run build",
    "offline": "npm run build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "jspdf": "^4.2.1",
    "pinia": "^2.1.7",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/eslint-config-typescript": "^14.1.3",
    "eslint": "^9.15.0",
    "eslint-plugin-vue": "^9.31.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.2.0"
  }
}
